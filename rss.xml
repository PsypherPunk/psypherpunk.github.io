&lt;&#x2F;span&gt;&lt;&#x2F;code&gt;&lt;&#x2F;pre&gt;
&lt;p&gt;Those base64 strings are passed through &lt;code&gt;function d&lt;&#x2F;code&gt;:&lt;&#x2F;p&gt;
&lt;pre data-lang=&quot;pwsh&quot; class=&quot;language-pwsh z-code&quot;&gt;&lt;code class=&quot;language-pwsh&quot; data-lang=&quot;pwsh&quot;&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;function d {
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;    param ([string]$mm, [string]$k)
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;    try {
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        $b = [System.Convert]::FromBase64String($mm);
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        $s = [System.Text.Encoding]::UTF8.GetString($b);
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        $d = New-Object char[] $s.Length;
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        for ($i = 0; $i -lt $s.Length; $i++) {
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;            $c = $s[$i];
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;            $p = $k[$i % $k.Length];
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;            $d[$i] = [char]($c - $p)
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        };
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        return -join $d
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;    } catch {
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;        throw
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;    }
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;};
