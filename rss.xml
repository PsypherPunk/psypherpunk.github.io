&lt;&#x2F;span&gt;&lt;span class=&quot;z-source z-actionscript z-2&quot;&gt;   &lt;span class=&quot;z-constant z-numeric z-actionscript z-2&quot;&gt;0x7ffff7fbf00b&lt;&#x2F;span&gt;    xor    r10, r10           R10 &lt;span class=&quot;z-keyword z-operator z-symbolic z-actionscript z-2&quot;&gt;=&lt;&#x2F;span&gt;&amp;gt; &lt;span class=&quot;z-constant z-numeric z-actionscript z-2&quot;&gt;0&lt;&#x2F;span&gt;
