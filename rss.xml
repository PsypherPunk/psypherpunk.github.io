&lt;&#x2F;span&gt;&lt;span&gt;    input_ = [&lt;&#x2F;span&gt;&lt;span style=&quot;color:#d08770;&quot;&gt;0&lt;&#x2F;span&gt;&lt;span&gt;] * length
&lt;&#x2F;span&gt;&lt;span&gt;
